<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="DummyJSON nopCommerce QA Capstone Suite" verbose="2" thread-count="1">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- ===== Authentication must run first (sets tokens) ===== -->
    <test name="01 - User Authentication">
        <classes>
            <class name="com.qa.tests.UserAuthenticationTest"/>
        </classes>
    </test>

    <!-- ===== Product Catalogue (stateless, no auth needed) ===== -->
    <test name="02 - Product Catalogue and Search">
        <classes>
            <class name="com.qa.tests.ProductCatalogueTest"/>
        </classes>
    </test>

    <!-- ===== Shopping Cart ===== -->
    <test name="03 - Shopping Cart">
        <classes>
            <class name="com.qa.tests.ShoppingCartTest"/>
        </classes>
    </test>

    <!-- ===== Checkout and Payment ===== -->
    <test name="04 - Checkout and Payment">
        <classes>
            <class name="com.qa.tests.CheckoutPaymentTest"/>
        </classes>
    </test>

    <!-- ===== Token Refresh ===== -->
    <test name="05 - Token Refresh and Session">
        <classes>
            <class name="com.qa.tests.TokenRefreshTest"/>
        </classes>
    </test>

    <!-- ===== Wishlist ===== -->
    <test name="06 - Wishlist">
        <classes>
            <class name="com.qa.tests.WishlistTest"/>
        </classes>
    </test>

    <!-- ===== Order Management ===== -->
    <test name="07 - Order Management">
        <classes>
            <class name="com.qa.tests.OrderManagementTest"/>
        </classes>
    </test>

    <!-- ===== User Profile ===== -->
    <test name="08 - User Profile Management">
        <classes>
            <class name="com.qa.tests.UserProfileTest"/>
        </classes>
    </test>

</suite>
